[MASTER]
ignore=CVS,
       .git,
       __pycache__,
       .env,
       venv,
       .venv
persistent=yes
max-line-length=120

[MESSAGES CONTROL]
disable=C0111,
        C0103,
        W0611,
        W0703,
        R0903,
        R0914,
        R0915,
        R0801,
        R1705

[REPORTS]
output-format=text
score=no
