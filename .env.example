# Kenya County Analytics - Environment Variables
# DO NOT commit actual secrets. Copy this file to .env and fill in values.

# OpenAI / LLM Configuration
OPENAI_API_KEY=
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# Anthropic (optional alternative)
ANTHROPIC_API_KEY=

# Ollama (local LLM alternative)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Discord webhook for n8n notifications
DISCORD_WEBHOOK_URL=

# Email SMTP (n8n)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true

# Data paths
DATA_ROOT=./data
RAW_DATA_DIR=./data/raw
PROCESSED_DATA_DIR=./data/processed
GEOSPATIAL_DIR=./data/geospatial

# Scraper Configuration
SCRAPER_RATE_LIMIT=2
SCRAPER_MAX_RETRIES=3
SCRAPER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs
